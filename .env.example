# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# Токен Cloudflare Tunnel.
# Где взять:
#   1. Перейди на https://one.dash.cloudflare.com/
#   2. Networks → Tunnels → Create a tunnel → Cloudflared
#   3. Назови тоннель (например "tga-prod")
#   4. Скопируй токен из раздела "Install and run a connector"
#      (строка вида: cloudflared tunnel run --token <TOKEN>)
#   5. В настройках тоннеля (Public Hostname) добавь маршрут:
#        Subdomain: tga (или нужный)
#        Domain:    твой-домен.com
#        Service:   http://app:8080
CLOUDFLARE_TUNNEL_TOKEN=paste_your_token_here
